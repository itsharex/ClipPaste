{
    "$schema": "https://schema.tauri.app/config/2.0.0",
    "productName": "ClipPaste",
    "version": "1.6.4",
    "identifier": "me.xueshi.clipboard",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "ClipPaste",
                "width": 1920,
                "height": 540,
                "minWidth": 700,
                "minHeight": 400,
                "resizable": false,
                "fullscreen": false,
                "decorations": false,
                "transparent": true,
                "shadow": false,
                "visible": false,
                "center": false,
                "label": "main",
                "dragDropEnabled": false
            }
        ],
        "security": {
            "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'",
            "capabilities": [
                "default"
            ]
        },
        "withGlobalTauri": true
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "publisher": "Phieu-Tran",
        "icon": [
            "icons/32x32.png",
            "icons/64x64.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/256x256.png",
            "icons/512x512.png",
            "icons/icon.ico",
            "icons/icon.icns"
        ],
        "createUpdaterArtifacts": true,
        "windows": {
            "nsis": {
                "displayLanguageSelector": false,
                "installerIcon": "icons/icon.ico",
                "headerImage": "icons/128x128.png"
            }
        },
        "macOS": {
            "minimumSystemVersion": "10.15"
        },
        "linux": {
            "deb": {
                "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
            },
            "appimage": {
                "bundleMediaFramework": false
            }
        }
    },
    "plugins": {
        "updater": {
            "endpoints": [
                "https://github.com/Phieu-Tran/ClipPaste/releases/latest/download/latest.json"
            ],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYyODUyNDFCNTYyQzk4QzEKUldUQm1DeFdHeVNGWXNDRmxzQUFHbWVveWx0d1B2Qzg5VFV6UzQ5Sjh0R1BqZ0VkMDE1Wm1uWVcK"
        }
    }
}
